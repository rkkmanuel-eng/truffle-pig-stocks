# Get a free API key at https://financialmodelingprep.com/developer
FMP_API_KEY=your_api_key_here

# Database directory (default: project root, Railway: /data)
# DB_DIR=

# JWT signing secret (REQUIRED in production — generate with: openssl rand -base64 32)
JWT_SECRET=

# Secret for cron refresh endpoint (optional — leave empty to allow unauthenticated)
CRON_SECRET=

# Twilio (optional — for SMS alerts)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
